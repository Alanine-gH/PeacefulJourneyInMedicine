<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.PJDM.mapper.PaymentRecordMapper">

    <!-- 分页查询支付记录 -->
    <select id="selectPaymentPage" resultType="com.PJDM.pojo.PaymentRecord">
        SELECT *
        FROM payment_record
        WHERE user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
