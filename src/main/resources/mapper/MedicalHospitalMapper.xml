<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.PJDM.mapper.MedicalHospitalMapper">

    <resultMap id="HospitalListVOMap" type="com.PJDM.vo.HospitalListVO">
        <id     column="id"                    property="id"/>
        <result column="hospital_code"         property="hospitalCode"/>
        <result column="hospital_name"         property="hospitalName"/>
        <result column="hospital_name_en"      property="hospitalNameEn"/>
        <result column="hospital_type"         property="hospitalType"/>
        <result column="hospital_level"        property="hospitalLevel"/>
        <result column="province"              property="province"/>
        <result column="city"                  property="city"/>
        <result column="address"               property="address"/>
        <result column="phone"                 property="phone"/>
        <result column="international_phone"   property="internationalPhone"/>
        <result column="has_international_dept" property="hasInternationalDept"/>
        <result column="is_cooperation"        property="isCooperation"/>
        <result column="cooperation_start_date" property="cooperationStartDate"/>
        <result column="logo_url"              property="logoUrl"/>
        <result column="rating_score"          property="ratingScore"/>
        <result column="comment_count"         property="commentCount"/>
        <result column="status"                property="status"/>
        <result column="sort"                  property="sort"/>
        <result column="featured_departments"  property="featuredDepartments"/>
        <result column="create_time"           property="createTime"/>
    </resultMap>

    <select id="selectHospitalListPage" resultMap="HospitalListVOMap">
        SELECT
        id, hospital_code, hospital_name, hospital_name_en,
        hospital_type, hospital_level, province, city, district, address,
        phone, international_phone, has_international_dept,
        is_cooperation, cooperation_start_date, logo_url,
        rating_score, comment_count, status, sort,
        featured_departments, create_time
        FROM medical_hospital
        <where>
            <if test="q.hospitalName != null and q.hospitalName != ''">
                AND hospital_name LIKE CONCAT('%', #{q.hospitalName}, '%')
            </if>
            <if test="q.province != null and q.province != ''">
                AND province = #{q.province}
            </if>
            <if test="q.city != null and q.city != ''">
                AND city = #{q.city}
            </if>
            <if test="q.district != null and q.district != ''">
                AND district = #{q.district}
            </if>
            <if test="q.hospitalType != null">
                AND hospital_type = #{q.hospitalType}
            </if>
            <if test="q.isCooperation != null">
                AND is_cooperation = #{q.isCooperation}
            </if>
            <if test="q.status != null">
                AND status = #{q.status}
            </if>
        </where>
    </select>

</mapper>
