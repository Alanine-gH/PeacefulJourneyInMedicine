    <!-- 查询用户详情（基础信息，直接从 user_user 表获取） -->
    <select id="selectUserDetail" resultMap="UserDetailVOMap">
        SELECT
            u.id,
            u.username,
            u.nick_name,
            u.real_name,
            u.phone,
            u.email,
            u.avatar_url,
            u.age,
            u.gender,
            u.user_type,
            u.status,
            u.last_login_time,
            u.last_login_ip,
            u.create_time,
            u.remark
        FROM user_user u
        WHERE u.id = #{id}
    </select>

