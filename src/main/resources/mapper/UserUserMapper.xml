    <!-- 查询用户详情（基础信息，角色由 selectRolesByUserId 单独查询） -->
    <select id="selectUserDetail" resultMap="UserDetailVOMap">
        SELECT
            u.id,
            u.username,
            u.nick_name,
            u.real_name,
            u.phone,
            u.email,
            u.avatar_url,
            u.age,
            u.gender,
            u.user_type,
            u.status,
            u.last_login_time,
            u.last_login_ip,
            u.create_time,
            u.remark
        FROM user_user u
        WHERE u.id = #{id}
    </select>

    <!-- 查询用户关联角色（user_user_role JOIN user_role 多表联查） -->
    <select id="selectRolesByUserId" resultMap="RoleSimpleVOMap">
        SELECT
            r.id   AS role_id,
            r.role_name,
            r.role_code
        FROM user_user_role ur
        INNER JOIN user_role r ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
          AND r.status = 1
        ORDER BY r.role_sort
    </select>

</mapper>
